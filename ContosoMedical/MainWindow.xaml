<Window x:Class="PatientSummaryTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:PatientSummaryTool"
        xmlns:resources="clr-namespace:PatientSummaryTool.Properties"
        xmlns:vms="clr-namespace:PatientSummaryTool.ViewModels"
        xmlns:converters="clr-namespace:PatientSummaryTool.Utils.Converters"
        xmlns:views="clr-namespace:PatientSummaryTool.Views"
        xmlns:behaviors="clr-namespace:PatientSummaryTool.Utils.Behaviors"
        xmlns:localSharedControls="clr-namespace:PatientSummaryTool.Views.SharedUserControls"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        mc:Ignorable="d"
        x:Name="PatientSummaryWindow"
        Title="Contoso Medical" Height="750" Width="1200">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vms:WelcomeViewModel}">
            <views:WelcomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:PatientViewModel}">
            <views:PatientView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:AddPatientViewModel}">
            <views:AddPatientView/>
        </DataTemplate>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:CallMethodAction TargetObject="{Binding}" MethodName="LoadMain" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <Grid Margin="5,10,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0,0,0,5">
                        <Image Source="/ImageAssets/logo.png" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Button Style="{StaticResource SearchButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Search Icon -->
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0" Foreground="Black"/>
                                    <TextBlock Text="{x:Static resources:Resources.SearchButtonText}" VerticalAlignment="Center" FontSize="14" Foreground="Black"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Grid Grid.Column="1">
                            <localSharedControls:BellNotification Margin="10,0,5,0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Grid.Column="2">
                            <localSharedControls:LoginIcon Margin="10,0,5,0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Border BorderBrush="LightGray" BorderThickness="0,0,1,0">
                    <Grid Margin="0,0,25,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="10,20">
                            <Grid>
                                <TextBlock Text="{x:Static resources:Resources.NavLabelHeading}" Style="{StaticResource NavLabelsHeading}" />
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <localSharedControls:LookupSymbol Margin="10,0,5,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            </Grid>
                            <Grid Grid.Column="1">
                                <Label Name="PatientLookupNavLabel" Content="{x:Static resources:Resources.PatientLookupNavLabel}" Style="{StaticResource NavLabels}" Foreground="{Binding ForegroundColors[0]}" Background="{Binding BackgroundColors[0]}" />
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <localSharedControls:HeartSymbol Margin="10,0,5,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            </Grid>
                            <Grid Grid.Column="1">
                                <Label Name="PatientRecordsNavLabel" Content="{x:Static resources:Resources.PatientRecordsNavLabel}" Style="{StaticResource NavLabels}" Foreground="{Binding ForegroundColors[1]}" Background="{Binding BackgroundColors[1]}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            <Grid Grid.Column="1" Margin="0,0,10,0">
                <ContentControl Focusable="False" Content="{Binding CurrentViewModel}" Grid.ColumnSpan="2"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
