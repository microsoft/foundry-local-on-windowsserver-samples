<UserControl x:Class="PatientSummaryTool.Views.PatientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:PatientSummaryTool"
             xmlns:resources="clr-namespace:PatientSummaryTool.Properties"
             xmlns:vms="clr-namespace:PatientSummaryTool.ViewModels"
             xmlns:converters="clr-namespace:PatientSummaryTool.Utils.Converters"
             xmlns:views="clr-namespace:PatientSummaryTool.Views"
             xmlns:behaviors="clr-namespace:PatientSummaryTool.Utils.Behaviors"
             xmlns:localSharedControls="clr-namespace:PatientSummaryTool.Views.SharedUserControls"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="700">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:BooleanVisibilityCollapsedConverter x:Key="booleanToVisibilityCollapsedConverter" />
            <converters:ObjectVisibilityHiddenConverter x:Key="visibilityHiddenConverter" />
            <converters:FirstNonEmptyConverter x:Key="FirstNonEmptyConverter"/>
            <BooleanToVisibilityConverter x:Key="booleanToVisibilityConverter" />
            <Style TargetType="TextBlock">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <CollectionViewSource x:Key="PatientsSortedCollection" Source="{Binding Patients}">
                <CollectionViewSource.SortDescriptions>
                    <scm:SortDescription PropertyName="FirstName"/>
                </CollectionViewSource.SortDescriptions>
            </CollectionViewSource>
        </ResourceDictionary>
    </UserControl.Resources>
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:CallMethodAction TargetObject="{Binding}" MethodName="LoadPatient" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="5,5,5,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Label Name="SelectPatientLabel" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SelectPatientLabelText" Text="{x:Static resources:Resources.PatientDropdownLabel}"/>
                            <TextBlock Text=" *" Foreground="#A4262C" />
                        </StackPanel>
                    </Label>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <ComboBox x:Name="SelectPatientComboBox" AutomationProperties.LabeledBy="{Binding ElementName=SelectPatientLabelText}" AutomationProperties.IsRequiredForForm="True" Style="{StaticResource ComboBox}" ItemsSource="{Binding Source={StaticResource PatientsSortedCollection}}" SelectedItem="{Binding PatientSelected, Mode=TwoWay}" IsEnabled="{Binding IsPatientBoxEnabled, Mode=TwoWay}" IsSynchronizedWithCurrentItem="False">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="SelectionChanged">
                                    <b:InvokeCommandAction Command="{Binding PatientSelectionChangedCommand}" />
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ComboBox>
                    </Grid>
                    <Grid Grid.Column="1" Margin="5,0,0,0">
                        <Button Name="AddPatientButton" Content="+" ToolTip="{x:Static resources:Resources.AddPatientButtonTooltip}" ToolTipService.InitialShowDelay="0" ToolTipService.Placement="Top" Command="{Binding AddPatientCommand}" Background="Transparent" Foreground="Green" BorderBrush="LightBlue" BorderThickness="1" Width="20" />
                    </Grid>
                </Grid>
            </Grid>
            <Grid Grid.Column="1" Margin="5,5,5,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <localSharedControls:LoadingSpinner Margin="0,0,10,5" Visibility="{Binding SummaryLoading, Converter={StaticResource booleanToVisibilityConverter}, Mode=TwoWay}" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Grid.Column="1">
                    <Button Name="SummarizeButton" Content="{x:Static resources:Resources.SummarizeButtonText}" Style="{StaticResource SummarizeButton}" Command="{Binding SummarizeCommand}" />
                </Grid>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Margin="5,5,5,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="30,15,30,0" Visibility="{Binding IsIntermediateSummariesAvailable, Converter={StaticResource booleanToVisibilityCollapsedConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding AllergiesSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding AllergiesSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding AllergiesSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.AllergiesIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding AllergiesSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Allergies">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding MedicationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding MedicationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding MedicationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.MedicationsIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding MedicationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Medications">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="2" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding ConditionsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding ConditionsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding ConditionsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.ConditionsIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding ConditionsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Conditions">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="3" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding CareplansSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding CareplansSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding CareplansSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.CarePlansIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding CareplansSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Care Plans">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="4" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding ReportsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding ReportsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding ReportsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.ReportsIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding ReportsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Reports">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="5" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding ObservationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding ObservationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding ObservationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.ObservationsIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding ObservationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Observations">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="6" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding ProceduresSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding ProceduresSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding ProceduresSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.ProceduresIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding ProceduresSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Procedures">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="7" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding ImmunizationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding ImmunizationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding ImmunizationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.ImmunizationsIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding ImmunizationsSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Immunizations">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="8" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding EncountersSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding EncountersSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding EncountersSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.EncountersIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding EncountersSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Encounters">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="9" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <localSharedControls:LoadingSpinner Visibility="{Binding ImagingStudiesSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                        <localSharedControls:FailureCheck Visibility="{Binding ImagingStudiesSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                        <localSharedControls:SuccessCheck Visibility="{Binding ImagingStudiesSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                        <TextBlock Width="170" Text="{x:Static resources:Resources.ImagingStudiesIntermediateSummary}" Padding="5 0 0 0" />
                        <TextBlock Padding="5 0 0 0" Visibility="{Binding ImagingStudiesSummaryStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}">
                            <Hyperlink Command="{Binding ShowIntermediateSummaryPopupCommand}" CommandParameter="Imaging Studies">
                                View
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Row="1" Margin="5,10,20,5" Visibility="{Binding IsTranslationStatusAvailable, Converter={StaticResource booleanToVisibilityCollapsedConverter}}">
                <StackPanel Orientation="Horizontal">
                    <localSharedControls:LoadingSpinner Visibility="{Binding TranslationStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Loading}, Mode=TwoWay}"/>
                    <localSharedControls:FailureCheck Visibility="{Binding TranslationStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}"/>
                    <localSharedControls:SuccessCheck Visibility="{Binding TranslationStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Success},Mode=TwoWay}"/>
                    <TextBlock Text="{x:Static resources:Resources.TranslationMessage}" Padding="5 0 0 0" />
                    <Button Margin="15,0,0,0" Name="RetryButtonTranslation" Content="Retry" Style="{StaticResource RetryButton}" Visibility="{Binding TranslationStatus, Converter={StaticResource visibilityHiddenConverter},ConverterParameter={x:Static vms:CheckStatus.Failure},Mode=TwoWay}" Command="{Binding RetryTranslationCommand}" />
                </StackPanel>
            </Grid>
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <TextBlock Text="{Binding Path=PatientBoxHeading}" Style="{StaticResource CollapsedTextBlock}" VerticalAlignment="Top"/>
            </Grid>
            <Grid Grid.Row="3">
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="2">
                    <Grid Margin="5,5,5,25">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" behaviors:AutoScrollBehavior.AutoScrollToEnd="True">
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource FirstNonEmptyConverter}">
                                        <Binding Path="PatientDetails" UpdateSourceTrigger="PropertyChanged"/>
                                        <Binding Path="PatientSummary" UpdateSourceTrigger="PropertyChanged"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <Popup 
            IsOpen="{Binding IsPopupOpen, Mode=TwoWay}" 
            Placement="Center"
            StaysOpen="False"
            AllowsTransparency="True"
            PopupAnimation="Fade">
            <Border Background="White" BorderBrush="Black" BorderThickness="1" CornerRadius="6" Padding="15" SnapsToDevicePixels="True" MinWidth="250" MaxWidth="600">
                <StackPanel>
                    <TextBlock Text="{Binding SectionName}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding PatientIntermediateSummary}" TextWrapping="Wrap"/>
                    </ScrollViewer>
                    <Button Content="Close" Width="80" Margin="0,10,0,0" HorizontalAlignment="Right" Command="{Binding CloseIntermediateSummaryPopupCommand}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
